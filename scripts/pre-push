#!/bin/sh
# pre-push hook — runs before git push
# Works on Windows (Git for Windows), macOS, and Linux
# Installation: python scripts/setup-hooks.py

uv run ruff format --check app/ tests/

if [ $? -ne 0 ]; then
    echo ""
    echo "Format check failed. Run 'uv run ruff format app/ tests/' to fix, then push again."
    echo ""
    exit 1
fi

exit 0
